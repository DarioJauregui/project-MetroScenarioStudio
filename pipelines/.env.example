# =============================================================================
# Credenciales Azure / SharePoint
# Copia este archivo a pipelines/.env y rellena valores reales fuera de Git.
# =============================================================================
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# =============================================================================
# Origen - SharePoint clasico / portal interno
# =============================================================================
SOURCE_SITE_URL=https://portal.metromalaga.es/conecta
SOURCE_LIST_NAME=EventosCalendario
PAGE_SIZE=5000


# =============================================================================
# Libreria interna de manejo de DataCenterBI Sharepoint
# =============================================================================
METRO_DATACENTER_BI_LIB_PATH=

# =============================================================================
# Salida
# =============================================================================
OUTPUT_NAME=Calendario_Eventos
SHEET_NAME=Eventos

# Solo elimina metadatos de API como __metadata, no columnas reales de SharePoint.
DROP_API_METADATA=true

INCLUDE_METADATA_SHEET=false
PREVENT_EMPTY_UPLOAD=true

# =============================================================================
# Configuracion de columnas
# =============================================================================
COLUMNS_MODE=auto
INCLUDE_SYSTEM_COLUMNS=Created,Modified
EXCLUDE_COLUMNS=FirstUniqueAncestorSecurableObject,RoleAssignments,AttachmentFiles,ContentType,FieldValuesAsHtml,FieldValuesAsText,FieldValuesForEdit,File,Folder,ParentList,FileSystemObjectType,GUID
