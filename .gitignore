# Entornos virtuales e IDEs
.venv/
.idea/
.vscode/
.env
**/.env
!.env.example
!**/.env.example
__pycache__/
*.pyc
*.egg-info/
build/
ml_pipeline/conf/local/config.toml
pipelines/config.json


# Directorios de datos locales temporales.
# Se ignoran los contenidos pesados, pero se permiten punteros DVC y .gitkeep.
data/raw/**
!data/raw/**/
!data/raw/.gitkeep
!data/raw/**/*.dvc
!data/raw/**/.gitignore
data/interim/**
!data/interim/**/
!data/interim/.gitkeep
!data/interim/**/*.dvc
!data/interim/**/.gitignore
data/processed/**
!data/processed/**/
!data/processed/.gitkeep
!data/processed/**/*.dvc
!data/processed/**/.gitignore
data/validation/**
!data/validation/**/
!data/validation/.gitkeep
!data/validation/**/*.dvc
!data/validation/**/.gitignore

# MLFlow y base de datos locales
mlruns/
platform/backend/storage/
*.db

# Logs y runtime locales
*.log
.pytest_cache/
.ruff_cache/
tmp/
*.tmp

# Node.js y Frontend
node_modules/
dist/
.vite/
.eslintcache
tsconfig.tsbuildinfo

# Artefactos de ML y monitoreo.
# Los binarios se gestionan con DVC; Git conserva solo punteros y metricas ligeras.
ml_pipeline/artifacts/**
!ml_pipeline/artifacts/**/
!ml_pipeline/artifacts/models/
!ml_pipeline/artifacts/models/**/*.dvc
!ml_pipeline/artifacts/models/**/.gitignore
!ml_pipeline/artifacts/monitoring/
!ml_pipeline/artifacts/monitoring/*.json
ml_pipeline/ml_pipeline/
ml_pipeline/docs/05_memory_support/
pipelines/pipeline.log
platform/frontend/dist/
